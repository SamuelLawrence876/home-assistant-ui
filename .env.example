# Copy this file to .env.local and fill in real values.
# .env.local is gitignored via the `*.local` rule in .gitignore.

# Home Assistant URL — used by both `npm run dev` and `npm run build`.
#   - Dev/LAN:  http://192.168.0.79:8123
#   - Prod:     https://ha.samuel-lawrence.com  (injected in CI via the
#                                                VITE_HA_URL repo variable)
VITE_HA_URL=http://192.168.0.79:8123

# Auth: handled at runtime via HA's OAuth flow (home-assistant-js-websocket).
# Tokens are stored in localStorage under `ha_tokens` and auto-refreshed.
# No token env var is needed — the app redirects to HA's login on first visit.
